// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String             @id
  name                String
  email               String             @unique
  emailVerified       Boolean
  image               String?
  role                user_role          @default(USER)
  status              User_Status        @default(ACTIVE)
  isDeleted           Boolean            @default(false)
  deletedAt           DateTime?
  needsPasswordChange Boolean            @default(false)
  createdAt           DateTime
  updatedAt           DateTime
  sessions            Session[]
  accounts            Account[]
  destinations        Destination[]
  reviews             Review[]
  itineraries         Itinerary[]
  savedDestinations   SavedDestination[]
  savedItineraries    SavedItinerary[]
  aiChats             AIChat[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// --- Destination Models ---
model Destination {
  id          String              @id @default(uuid())
  slug        String              @unique
  name        String
  description String              @db.Text
  location    String
  country     String
  category    DestinationCategory
  latitude    Decimal?            @db.Decimal(10, 8)
  longitude   Decimal?            @db.Decimal(11, 8)
  budgetMin   Decimal             @db.Decimal(10, 2)
  budgetMax   Decimal             @db.Decimal(10, 2)
  avgRating   Decimal             @default(0) @db.Decimal(3, 2)
  reviewCount Int                 @default(0)
  coverImage  String
  isPublished Boolean             @default(false)
  createdBy   String
  user        User                @relation(fields: [createdBy], references: [id])
  images      DestinationImage[]
  reviews     Review[]
  itineraries Itinerary[]
  savedBy     SavedDestination[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("destinations")
}

model DestinationImage {
  id            String      @id @default(uuid())
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  url           String
  altText       String?
  order         Int         @default(0)
  createdAt     DateTime    @default(now())

  @@map("destination_images")
}

model Review {
  id            String      @id @default(uuid())
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating        Int
  comment       String      @db.Text
  isHidden      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("reviews")
}

// --- Itinerary Models ---
model Itinerary {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  destinationId   String
  destination     Destination      @relation(fields: [destinationId], references: [id])
  title           String
  totalDays       Int
  budgetEstimate  Decimal          @db.Decimal(10, 2)
  travelStyle     String
  aiContextInput  Json // Stores the prompts/preferences used
  aiGeneratedPlan Json // The raw JSON returned by AI
  days            ItineraryDay[]
  savedBy         SavedItinerary[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("itineraries")
}

model ItineraryDay {
  id          String              @id @default(uuid())
  itineraryId String
  itinerary   Itinerary           @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  dayNumber   Int
  theme       String?
  activities  ItineraryActivity[]

  @@map("itinerary_days")
}

model ItineraryActivity {
  id             String       @id @default(uuid())
  itineraryDayId String
  day            ItineraryDay @relation(fields: [itineraryDayId], references: [id], onDelete: Cascade)
  name           String
  type           String
  cost           Decimal?     @db.Decimal(10, 2)
  location       String?
  time           String?
  order          Int          @default(0)

  @@map("itinerary_activities")
}

// --- AI Chat Models ---
model AIChat {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  messages  AIMessage[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("ai_chats")
}

model AIMessage {
  id        String      @id @default(uuid())
  chatId    String
  chat      AIChat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String      @db.Text
  meta      Json?
  createdAt DateTime    @default(now())

  @@map("ai_messages")
}

// --- Saved/Bookmark Models ---
model SavedDestination {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([userId, destinationId])
  @@map("saved_destinations")
}

model SavedItinerary {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itineraryId String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, itineraryId])
  @@map("saved_itineraries")
}

// --- Analytics & Enums ---
model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String?
  eventType String
  payload   Json
  createdAt DateTime @default(now())

  @@map("analytics_events")
}

enum user_role {
  USER
  ADMIN
  CONTENT_MANAGER
}

enum User_Status {
  ACTIVE
  BLOCKED
}

enum DestinationCategory {
  beach
  mountain
  city
  adventure
  cultural
}

enum MessageRole {
  user
  assistant
  system
}

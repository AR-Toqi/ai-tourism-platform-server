{
	"info": {
		"name": "AI Tourism Platform API",
		"description": "Complete API collection for the AI Tourism Platform backend. Base URL: http://localhost:5000/api/v1",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
		{ "key": "accessToken", "value": "" },
		{ "key": "destinationId", "value": "" },
		{ "key": "destinationSlug", "value": "" },
		{ "key": "itineraryId", "value": "" },
		{ "key": "reviewId", "value": "" },
		{ "key": "chatId", "value": "" },
		{ "key": "userId", "value": "" },
		{ "key": "imageId", "value": "" }
	],
	"auth": {
		"type": "bearer",
		"bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/auth/register",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
						}
					}
				},
				{
					"name": "Login",
					"event": [{
						"listen": "test",
						"script": {
							"exec": ["var json = pm.response.json();", "if(json.data && json.data.accessToken) { pm.collectionVariables.set('accessToken', json.data.accessToken); }"]
						}
					}],
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/auth/login",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
						}
					}
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/auth/refresh-token",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{}" }
					}
				},
				{
					"name": "Change Password",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/auth/change-password",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"oldPassword\": \"password123\",\n  \"newPassword\": \"newPassword456\"\n}"
						}
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/auth/logout"
					}
				},
				{
					"name": "Verify Email",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/auth/verify-email",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"john@example.com\",\n  \"otp\": \"123456\"\n}"
						}
					}
				},
				{
					"name": "Forgot Password",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/auth/forgot-password",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"john@example.com\"\n}"
						}
					}
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/auth/reset-password",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"john@example.com\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"newPassword789\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "User",
			"item": [
				{
					"name": "Get My Profile",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/users/me"
					}
				},
				{
					"name": "Update My Profile (with image)",
					"request": {
						"method": "PATCH",
						"url": "{{baseUrl}}/users/me",
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "name", "value": "John Updated", "type": "text" },
								{ "key": "image", "type": "file", "src": "" }
							]
						}
					}
				},
				{
					"name": "Delete My Account",
					"request": {
						"method": "DELETE",
						"url": "{{baseUrl}}/users/me"
					}
				}
			]
		},
		{
			"name": "Admin",
			"item": [
				{
					"name": "Get Dashboard Stats",
					"request": { "method": "GET", "url": "{{baseUrl}}/admin/dashboard-stats" }
				},
				{
					"name": "Update Admin Profile",
					"request": {
						"method": "PUT",
						"url": "{{baseUrl}}/admin/profile",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"name\": \"Super Admin\"\n}" }
					}
				},
				{
					"name": "Get Normal Users",
					"request": { "method": "GET", "url": "{{baseUrl}}/admin/users/normal" }
				},
				{
					"name": "Get Content Managers",
					"request": { "method": "GET", "url": "{{baseUrl}}/admin/users/content-managers" }
				},
				{
					"name": "Change User Status",
					"request": {
						"method": "PUT",
						"url": "{{baseUrl}}/admin/users/{{userId}}/status",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"status\": \"BLOCKED\"\n}" }
					}
				},
				{
					"name": "Change User Role",
					"request": {
						"method": "PUT",
						"url": "{{baseUrl}}/admin/users/{{userId}}/role",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"role\": \"CONTENT_MANAGER\"\n}" }
					}
				},
				{
					"name": "Soft Delete User",
					"request": { "method": "DELETE", "url": "{{baseUrl}}/admin/users/{{userId}}" }
				},
				{
					"name": "Get All Itineraries (Admin)",
					"request": { "method": "GET", "url": "{{baseUrl}}/admin/itineraries" }
				},
				{
					"name": "Get Itinerary By ID (Admin)",
					"request": { "method": "GET", "url": "{{baseUrl}}/admin/itineraries/{{itineraryId}}" }
				}
			]
		},
		{
			"name": "Destinations",
			"item": [
				{
					"name": "Create Destination",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/destinations",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Cox's Bazar Beach\",\n  \"description\": \"The longest natural sea beach in the world.\",\n  \"location\": \"Cox's Bazar\",\n  \"country\": \"Bangladesh\",\n  \"category\": \"beach\",\n  \"latitude\": 21.4272,\n  \"longitude\": 92.0058,\n  \"budgetMin\": 50,\n  \"budgetMax\": 500,\n  \"coverImage\": \"https://example.com/coxs-bazar.jpg\",\n  \"images\": [\n    { \"url\": \"https://example.com/img1.jpg\", \"altText\": \"Sunset view\" },\n    { \"url\": \"https://example.com/img2.jpg\", \"altText\": \"Beach walk\" }\n  ]\n}"
						}
					}
				},
				{
					"name": "Get All Destinations",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/destinations?page=1&limit=10&sortBy=createdAt&sortOrder=desc",
							"host": ["{{baseUrl}}"],
							"path": ["destinations"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" },
								{ "key": "searchTerm", "value": "", "disabled": true },
								{ "key": "category", "value": "beach", "disabled": true },
								{ "key": "budgetMin", "value": "50", "disabled": true },
								{ "key": "budgetMax", "value": "500", "disabled": true },
								{ "key": "sortBy", "value": "createdAt" },
								{ "key": "sortOrder", "value": "desc" }
							]
						}
					}
				},
				{
					"name": "Get Single Destination (by slug)",
					"request": { "method": "GET", "url": "{{baseUrl}}/destinations/{{destinationSlug}}" }
				}
			]
		},
		{
			"name": "Content Manager",
			"item": [
				{
					"name": "Update Destination Details",
					"request": {
						"method": "PATCH",
						"url": "{{baseUrl}}/content-manager/destinations/{{destinationId}}",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"description\": \"Updated description for this destination.\",\n  \"isPublished\": true\n}"
						}
					}
				},
				{
					"name": "Update Destination Cover Image",
					"request": {
						"method": "PATCH",
						"url": "{{baseUrl}}/content-manager/destinations/{{destinationId}}/cover",
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "coverImage", "type": "file", "src": "" }
							]
						}
					}
				},
				{
					"name": "Add Destination Gallery Images",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/content-manager/destinations/{{destinationId}}/images",
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "images", "type": "file", "src": "" },
								{ "key": "images", "type": "file", "src": "" }
							]
						}
					}
				},
				{
					"name": "Update Gallery Image",
					"request": {
						"method": "PATCH",
						"url": "{{baseUrl}}/content-manager/destinations/images/{{imageId}}",
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "image", "type": "file", "src": "" },
								{ "key": "altText", "value": "Updated alt text", "type": "text" },
								{ "key": "order", "value": "1", "type": "text" }
							]
						}
					}
				},
				{
					"name": "Delete Gallery Image",
					"request": { "method": "DELETE", "url": "{{baseUrl}}/content-manager/destinations/images/{{imageId}}" }
				}
			]
		},
		{
			"name": "Itineraries",
			"item": [
				{
					"name": "Create Itinerary (AI Generated)",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/itineraries",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"destinationId\": \"{{destinationId}}\",\n  \"title\": \"3-Day Cox's Bazar Adventure\",\n  \"totalDays\": 3,\n  \"budgetEstimate\": 300,\n  \"travelStyle\": \"adventure\",\n  \"preferences\": \"I love seafood and water sports\",\n  \"startDate\": \"2026-06-15T00:00:00.000Z\"\n}"
						}
					}
				},
				{
					"name": "Get My Itineraries",
					"request": { "method": "GET", "url": "{{baseUrl}}/itineraries/my-itineraries" }
				},
				{
					"name": "Get Single Itinerary",
					"request": { "method": "GET", "url": "{{baseUrl}}/itineraries/{{itineraryId}}" }
				}
			]
		},
		{
			"name": "Reviews",
			"item": [
				{
					"name": "Create Review",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/reviews",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"destinationId\": \"{{destinationId}}\",\n  \"rating\": 5,\n  \"comment\": \"Absolutely breathtaking! The beach was pristine and the locals were very welcoming.\"\n}"
						}
					}
				},
				{
					"name": "Get Destination Reviews",
					"request": { "method": "GET", "url": "{{baseUrl}}/reviews/{{destinationId}}" }
				},
				{
					"name": "Delete Review",
					"request": { "method": "DELETE", "url": "{{baseUrl}}/reviews/{{reviewId}}" }
				}
			]
		},
		{
			"name": "Saved / Bookmarks",
			"item": [
				{
					"name": "Toggle Save Destination",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/saved/destination",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"destinationId\": \"{{destinationId}}\"\n}" }
					}
				},
				{
					"name": "Toggle Save Itinerary",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/saved/itinerary",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"itineraryId\": \"{{itineraryId}}\"\n}" }
					}
				},
				{
					"name": "Get My Saved Items",
					"request": { "method": "GET", "url": "{{baseUrl}}/saved" }
				}
			]
		},
		{
			"name": "AI Chat",
			"item": [
				{
					"name": "Create Chat",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/ai-chat",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"title\": \"Planning a trip to Sylhet\"\n}" }
					}
				},
				{
					"name": "Send Message",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/ai-chat/send",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"chatId\": \"{{chatId}}\",\n  \"message\": \"What are the best places to visit in Sylhet in December?\"\n}" }
					}
				},
				{
					"name": "Get My Chats",
					"request": { "method": "GET", "url": "{{baseUrl}}/ai-chat/my-chats" }
				},
				{
					"name": "Get Chat Messages",
					"request": { "method": "GET", "url": "{{baseUrl}}/ai-chat/{{chatId}}/messages" }
				}
			]
		}
	]
}
